{
  "expo": {
    "name": "AmyNest AI",
    "slug": "amynest-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "amynest-mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/amynest-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8F7FF",
      "dark": {
        "image": "./assets/images/amynest-logo.png",
        "resizeMode": "contain",
        "backgroundColor": "#1A1530"
      }
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.amynest.ai",
      "googleServicesFile": "./GoogleService-Info.plist",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "AmyNest needs access to your photos so you can set a profile picture for your child.",
        "NSCameraUsageDescription": "AmyNest needs access to your camera so you can take a profile picture for your child.",
        "NSMicrophoneUsageDescription": "AmyNest uses the microphone for voice features in Amy AI Coach (optional).",
        "NSUserTrackingUsageDescription": "We don't track you across other apps. This is only used if you explicitly enable referral attribution.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.amynest.ai",
      "googleServicesFile": "./google-services.json",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#F8F7FF"
      },
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "AmyNest needs access to your photos so you can set a profile picture for your child.",
          "cameraPermission": "AmyNest needs access to your camera so you can take a profile picture for your child."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#7C3AED"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/amynest-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F8F7FF",
          "dark": {
            "image": "./assets/images/amynest-logo.png",
            "backgroundColor": "#1A1530"
          },
          "android": {
            "image": "./assets/images/adaptive-icon.png",
            "imageWidth": 180,
            "backgroundColor": "#F8F7FF"
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "f9d316ff-ff45-41d5-aa2d-4fa49a82cff2"
      }
    }
  }
}
