modules = ["nodejs-24", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test-routine-meals"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test-mealrecipecard-ui"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test-mobile-recipe-card"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test-ai-routine-pipeline"

[[workflows.workflow]]
name = "test-routine-meals"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace/artifacts/api-server && pnpm run test"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "test-mealrecipecard-ui"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace/artifacts/kidschedule && pnpm run test"

[[workflows.workflow]]
name = "test-mobile-recipe-card"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace/artifacts/amynest-mobile && pnpm run test"

[[workflows.workflow]]
name = "test-ai-routine-pipeline"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/api-server && pnpm run test:ai-pipeline"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0", "revenuecat:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

