modules = ["nodejs-24", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3002

[[ports]]
localPort = 20703
externalPort = 3000

[[ports]]
localPort = 20704
externalPort = 3001

[[ports]]
localPort = 21342
externalPort = 5000

[[ports]]
localPort = 25261
externalPort = 3003

[[ports]]
localPort = 25262
externalPort = 4200

[userenv]

[userenv.shared]
GOOGLE_API_KEY = "AIzaSyA-QhjL9G-WEfqjyAVHl1kaVkz1LTrRJNo"

[nix]
channel = "stable-25_05"
